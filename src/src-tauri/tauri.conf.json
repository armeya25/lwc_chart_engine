{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Chart Terminal",
  "version": "0.9.2",
  "identifier": "com.armeya.chart-terminal",
  "build": {
    "frontendDist": "../src-frontend/dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Chart Terminal",
        "width": 1400,
        "height": 900,
        "minWidth": 800,
        "minHeight": 500,
        "center": true,
        "decorations": false,
        "transparent": true,
        "closable": true,
        "minimizable": true,
        "maximizable": true,
        "alwaysOnTop": false,
        "fullscreen": false,
        "skipTaskbar": false,
        "titleBarStyle": "Visible"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
